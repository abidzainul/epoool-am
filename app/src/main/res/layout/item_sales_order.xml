<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardUseCompatPadding="true"
    app:cardElevation="2dp"
    app:cardCornerRadius="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header: Distributor and Delivery Date -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tv_distributor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:text="Distributor"
                android:textColor="#000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_toLeftOf="@+id/tv_delivery_date"
                android:layout_marginEnd="8dp"
                android:layout_marginRight="8dp" />

            <TextView
                android:id="@+id/tv_delivery_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:text="01/01/2026"
                android:textColor="#000"
                android:textSize="12sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- Material and Release Total DO -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_material"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:text="Material Name"
                android:textColor="#000"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_toLeftOf="@+id/tv_qty"
                android:layout_marginEnd="8dp"
                android:layout_marginRight="8dp" />

            <TextView
                android:id="@+id/tv_qty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:text="0"
                android:textColor="#000"
                android:textSize="13sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- Timeline Shipping Progress -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Origin Point -->
            <RelativeLayout
                android:id="@+id/rl_origin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/iv_origin_dot"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/dot_green" />

                <TextView
                    android:id="@+id/tv_nama_gudang"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:layout_toRightOf="@+id/iv_origin_dot"
                    android:text="Gudang"
                    android:textColor="@color/app_green"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </RelativeLayout>

            <!-- Timeline Dots - District -->
            <ImageView
                android:id="@+id/iv_timeline_dot_1"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_below="@+id/rl_origin"
                android:layout_marginTop="2dp"
                android:src="@drawable/dot_line_vertical"
                app:tint="@color/material_grey_400" />

            <TextView
                android:id="@+id/tv_address_gudang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/rl_origin"
                android:layout_marginLeft="5dp"
                android:layout_toRightOf="@+id/iv_timeline_dot_1"
                android:text=""
                android:textColor="@color/material_grey_700"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <ImageView
                android:id="@+id/iv_timeline_dot_3"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_below="@+id/tv_address_gudang"
                android:src="@drawable/dot_line_vertical"
                app:tint="@color/material_grey_400" />

            <!-- Destination Point -->
            <RelativeLayout
                android:id="@+id/rl_destination"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/iv_timeline_dot_3"
                android:layout_marginTop="2dp">

                <ImageView
                    android:id="@+id/iv_destination_dot"
                    android:layout_width="12dp"
                    android:layout_height="14dp"
                    android:layout_marginTop="1.5dp"
                    android:src="@drawable/dot_orange" />

                <TextView
                    android:id="@+id/tv_name_ship_to"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:layout_toRightOf="@+id/iv_destination_dot"
                    android:text="Ship To"
                    android:textColor="@color/yellow"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </RelativeLayout>

            <TextView
                android:id="@+id/tv_address_ship_to"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/rl_destination"
                android:layout_marginLeft="17dp"
                android:text=""
                android:textColor="@color/material_grey_700"
                android:textSize="11sp"
                android:maxLines="2"
                android:ellipsize="end" />

        </RelativeLayout>

        <LinearLayout
            android:id="@+id/linearButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="vertical"
            android:background="@android:color/transparent">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/btn_request"
                    android:background="@drawable/bg_button_rounded_blue"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentRight="true"
                    android:text="Request"
                    android:textSize="12sp"/>

            </RelativeLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>

